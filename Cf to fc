#include <stdio.h>

int main() {
    float c, f;

    printf("Enter temperature in Celsius: ");
    scanf("%f", &c);

    f = (9.0/5.0) * c + 32;
    printf("Fahrenheit = %.2f\n", f);

    printf("Enter temperature in Fahrenheit: ");
    scanf("%f", &f);

    c = (5.0/9.0) * (f - 32);
    printf("Celsius = %.2f", c);

    return 0;
}
