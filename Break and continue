#include <stdio.h>

int main() {
    int i;

    printf("Demonstrating break statement:\n");
    for(i = 1; i <= 10; i++) {
        if(i == 6) {
            break;   // Exit loop when i = 6
        }
        printf("%d ", i);
    }

    printf("\n\nDemonstrating continue statement:\n");
    for(i = 1; i <= 10; i++) {
        if(i == 6) {
            continue;  // Skip when i = 6
        }
        printf("%d ", i);
    }

    return 0;
}
